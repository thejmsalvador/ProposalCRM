# ProposalCRM — environment variables
#
# Copy this file to .env (server-only secrets + DATABASE_URL) and/or .env.local
# (NEXT_PUBLIC_* values needed client-side) and fill in real values. Never commit
# real secrets — this file should only ever contain placeholders.

# Database (Supabase Postgres connection string, used by Prisma)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Supabase project URL and public keys (safe to expose client-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
# Alias read by some existing code paths — same value as the publishable key above
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Supabase service role key — server-only, never expose to the client.
# Dashboard: Settings > API > service_role key.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Signs the internal Puppeteer PDF URL (app/pdf/[proposalId]) with an HMAC so it
# can't be hit directly without a valid token. Required in production; skipped
# in development so the PDF template can be previewed unauthenticated.
PDF_SECRET=a-long-random-string

# Public app URL — used to build absolute links (emails, the PDF render target)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email via Resend (https://resend.com -> Dashboard -> API Keys)
RESEND_API_KEY=your-resend-api-key

# Supabase Storage bucket that generated PDFs are uploaded to
STORAGE_BUCKET_NAME=proposals

# Hours a proposal can sit PENDING_APPROVAL before the SLA cron sends a reminder
APPROVAL_SLA_HOURS=48

# Shared secret checked against the `Authorization: Bearer` header on cron routes
# (/api/cron/approval-sla, /api/cron/expire-proposals)
CRON_SECRET=a-long-random-string
